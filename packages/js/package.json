{
  "name": "lipilekhika",
  "version": "1.0.9",
  "type": "module",
  "license": "MIT",
  "homepage": "https://lipilekhika.in",
  "description": "A transliteration library for Indian Brahmic scripts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shubhattin/lipilekhika.git"
  },
  "keywords": [
    "indic-scripts",
    "transliteration",
    "typing"
  ],
  "sideEffects": false,
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/lipilekhika.umd.js",
  "jsdelivr": "./dist/lipilekhika.umd.js",
  "browser": "./dist/lipilekhika.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/esm/node.mjs",
      "require": "./dist/cjs/node.cjs"
    },
    "./typing": {
      "types": "./dist/typing.d.ts",
      "import": "./dist/esm/typing.mjs",
      "require": "./dist/cjs/typing.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "check": "tsc --noEmit",
    "test": "vitest",
    "test:bun": "bun test --concurrent --only-failures",
    "test:ui": "vitest --ui",
    "test:run": "vitest --run",
    "coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "lint": "eslint .",
    "make-script-data": "bun src/make_script_data/make_output_script_data.ts",
    "publish:cli": "bun run build && npm publish",
    "bench": "vite-node src/scripts/benchmark.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.6",
    "@types/bun": "^1.3.12",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "unplugin-macros": "^0.18.7",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
